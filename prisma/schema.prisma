generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  username           String?   @unique
  displayUsername    String?   @unique
  name               String
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  role               String    @default("user")
  banned             Boolean?  @default(false)
  banReason          String?
  banExpires         DateTime?
  performanceCredits Int       @default(0)
  streakDays         Int       @default(0)
  lastAttemptAt      DateTime?
  lastDecayAt        DateTime?
  rankShieldUntil    DateTime?
  accounts           Account[]
  sessions           Session[]
  tests              Test[]
  attempts           Attempt[]
  broadcasts         BroadcastMessage[]
  savedQuestions    SavedQuestion[]
  hostedMatches     MatchRoom[] @relation("MatchRoomHost")
  matchParticipants MatchParticipant[]
  matchAnswers      MatchAnswer[]
  pyqAttempts       PyqAttempt[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Account {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  providerId            String
  accountId             String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  impersonatedBy String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  value      String
  expiresAt  DateTime
  identifier String
}

model Test {
  id               String     @id @default(cuid())
  title            String
  description      String?
  tags             String[]  @default([])
  pdfUrl           String?
  visibility       String
  hidden          Boolean   @default(false)
  isPyq           Boolean   @default(false)
  isYearPaper     Boolean   @default(false)
  exam            String?
  examId          String?
  examRef         Exam?     @relation(fields: [examId], references: [id], onDelete: SetNull)
  examPapers      ExamPaper[]
  year            Int?
  shift           String?
  stream          String?
  accessCode       String?
  durationMinutes  Int
  markingCorrect   Int
  markingIncorrect Int
  lockNavigation   Boolean    @default(false)
  ownerId          String
  owner            User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions        Question[]
  attempts         Attempt[]
  percentileBands  TestPercentileBand[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Question {
  id             String   @id @default(cuid())
  testId         String
  subject        String
  difficulty     String
  questionType   String
  chapter        String?
  topic          String?
  correctOption  String?
  correctNumeric String?
  marksCorrect   Int
  marksIncorrect Int
  imageUrl       String
  cropX          Float
  cropY          Float
  cropW          Float
  cropH          Float
  prompt         String?
  solution       String?
  options        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  test           Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  savedBy       SavedQuestion[]
  matchQuestions MatchQuestion[]
  matchAnswers   MatchAnswer[]
  pyqAttempts    PyqAttempt[]
}

model Attempt {
  id                 String   @id @default(cuid())
  testId             String
  userId             String
  candidateName      String?
  batchCode          String?
  status             String   @default("DRAFT")
  answers            Json
  timeSpent          Json
  events             Json?
  score              Int      @default(0)
  accuracy           Float    @default(0)
  timeTaken          Int      @default(0)
  performanceCredits Int      @default(0)
  streakMultiplier   Float    @default(1.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  test               Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestPercentileBand {
  id              String   @id @default(cuid())
  testId          String
  minScore        Int
  maxScore        Int?
  percentileLabel String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  test            Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@unique([testId, minScore])
}


model BroadcastMessage {
  id          String   @id @default(cuid())
  title       String
  body        String
  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
}


model Exam {
  id        String     @id @default(cuid())
  name      String     @unique
  shortCode String?
  order     Int        @default(0)
  active    Boolean    @default(true)
  tests     Test[]
  papers    ExamPaper[]
  chapters  Chapter[]
  matches   MatchRoom[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Chapter {
  id        String   @id @default(cuid())
  examId    String?
  subject   String
  name      String
  iconUrl   String?
  order     Int      @default(0)
  topics    Topic[]
  exam      Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examId])
  @@unique([examId, subject, name])
}

model Topic {
  id        String   @id @default(cuid())
  chapterId String
  name      String
  order     Int      @default(0)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, name])
}

model ExamPaper {
  id        String   @id @default(cuid())
  examId    String
  year      Int
  shift     String?
  pdfUrl    String
  testId    String?
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  test      Test?    @relation(fields: [testId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examId, year])
}

model SavedQuestion {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model AppConfig {
  key             String   @id
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PyqAttempt {
  id         String   @id @default(cuid())
  userId     String
  examId     String?
  examName   String?
  questionId String
  subject    String?
  chapter    String?
  topic      String?
  answer     String?
  isCorrect  Boolean  @default(false)
  timeSpent  Int?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, examId])
  @@index([createdAt])
}

model MatchRoom {
  id               String            @id @default(cuid())
  code             String            @unique
  hostId           String
  host             User              @relation("MatchRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  mode             String
  visibility       String
  examId           String?
  examRef          Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  year             Int?
  subject          String?
  questionCount    Int
  timeLimitMinutes Int
  status           String            @default("LOBBY")
  startAt          DateTime?
  endAt            DateTime?
  participants     MatchParticipant[]
  questions        MatchQuestion[]
  answers          MatchAnswer[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([examId])
}

model MatchParticipant {
  id          String     @id @default(cuid())
  roomId      String
  userId      String
  score       Int        @default(0)
  accuracy    Float      @default(0)
  correct     Int        @default(0)
  wrong       Int        @default(0)
  skipped     Int        @default(0)
  joinedAt    DateTime   @default(now())
  finishedAt  DateTime?
  room        MatchRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model MatchQuestion {
  id         String    @id @default(cuid())
  roomId     String
  questionId String
  order      Int
  room       MatchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([roomId, questionId])
  @@index([roomId])
}

model MatchAnswer {
  id         String    @id @default(cuid())
  roomId     String
  userId     String
  questionId String
  answer     String?
  isCorrect  Boolean   @default(false)
  timeSpent  Int?
  createdAt  DateTime  @default(now())
  room       MatchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, questionId])
  @@index([roomId, userId])
}
